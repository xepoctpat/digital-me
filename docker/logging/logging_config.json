{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "standard": {
      "format": "%(asctime)s [%(levelname)s] %(name)s:%(funcName)s:%(lineno)d - %(message)s"
    },
    "json": {
      "()": "pythonjsonlogger.jsonlogger.JsonFormatter",
      "format": "%(timestamp)s %(level)s %(name)s %(message)s %(funcName)s %(lineno)d"
    },
    "detailed_json": {
      "()": "pythonjsonlogger.jsonlogger.JsonFormatter",
      "format": "%(timestamp)s %(level)s %(name)s %(message)s %(funcName)s %(lineno)d %(module)s %(pathname)s %(processName)s %(process)d %(threadName)s %(thread)d"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "standard",
      "stream": "ext://sys.stdout"
    },
    "file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "DEBUG",
      "formatter": "json",
      "filename": "/app/logs/app.json.log",
      "maxBytes": 10485760,
      "backupCount": 10,
      "encoding": "utf-8"
    },
    "error_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "ERROR",
      "formatter": "detailed_json",
      "filename": "/app/logs/error.json.log",
      "maxBytes": 10485760,
      "backupCount": 5,
      "encoding": "utf-8"
    },
    "access_file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "INFO",
      "formatter": "json",
      "filename": "/app/logs/access.json.log",
      "maxBytes": 52428800,
      "backupCount": 20,
      "encoding": "utf-8"
    }
  },
  "loggers": {
    "": {
      "level": "DEBUG",
      "handlers": ["console", "file", "error_file"]
    },
    "lpm_kernel": {
      "level": "DEBUG",
      "handlers": ["console", "file", "error_file"],
      "propagate": false
    },
    "flask": {
      "level": "INFO",
      "handlers": ["console", "access_file"],
      "propagate": false
    },
    "werkzeug": {
      "level": "INFO",
      "handlers": ["console", "access_file"],
      "propagate": false
    }
  }
}
